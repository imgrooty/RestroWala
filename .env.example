# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hotel_db?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="Generate-a-secret-key-for-production"

# Redis (for caching/sockets)
REDIS_URL="redis://localhost:6379"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Upload Limits
NEXT_PUBLIC_MAX_UPLOAD_SIZE="10485760" # 10MB in bytes
